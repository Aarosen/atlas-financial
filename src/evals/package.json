{
  "name": "atlas-evals",
  "version": "2.0.0",
  "description": "Atlas AI Championship Evaluation Framework",
  "scripts": {
    "eval:code":    "ts-node src/evals/code/runAll.ts",
    "eval:llm":     "ts-node src/evals/llm/runAll.ts",
    "eval:offline": "ts-node src/runner.ts --mode offline",
    "eval:online":  "ts-node src/runner.ts --mode online",
    "eval:gate":    "ts-node src/runner.ts --mode gate",
    "eval:atlas-v1": "ts-node src/v1/runner.ts",
    "eval:atlas-v1:validate": "ts-node src/v1/validateSuite.ts",
    "eval:atlas-v1:tags": "ts-node src/v1/tagCoverage.ts",
    "eval:failure:cluster": "ts-node src/failureClustering/clusterFailures.ts",
    "eval:generate:drafts": "ts-node src/generateDraftEvals.ts",
    "eval:promote:drafts": "ts-node src/promoteEvals.ts",
    "eval:generate:retirement": "ts-node src/generateRetirementCandidates.ts",
    "eval:retire:evals": "ts-node src/retireEvals.ts",
    "eval:score:health": "ts-node src/scoreEvalHealth.ts",
    "eval:analyze:portfolio": "ts-node src/analyzePortfolioBalance.ts",
    "eval:evaluate:governance": "ts-node src/evaluateGovernance.ts",
    "eval:dashboard": "ts-node src/buildReleaseDashboard.ts",
    "eval:weighting": "ts-node src/calculateAdaptiveWeighting.ts",
    "eval:tune:policies": "ts-node src/tunePolicies.ts",
    "report":       "ts-node src/reports/report.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0",
    "@types/node": "^20.0.0"
  }
}
